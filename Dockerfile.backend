# Use a Python image that supports our ML frameworks
FROM python:3.10-slim

WORKDIR /app

COPY python-ml-backend/requirements.txt .

# Install dependencies (ignoring missing GPU drivers in standard docker build)
RUN pip install --no-cache-dir -r requirements.txt

COPY python-ml-backend/ .

EXPOSE 8000

# Start FastAPI server
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
